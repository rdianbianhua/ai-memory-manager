{
  "name": "ai-memory",
  "version": "0.1.0",
  "description": "Developer AI Memory System - Long-term memory for AI coding assistants",
  "type": "module",
  "scripts": {
    "build": "npm run build:backend && npm run build:gui",
    "build:backend": "tsc",
    "build:gui": "vite build",
    "typecheck:gui": "vue-tsc --noEmit -p src/renderer/tsconfig.json",
    "check": "npm run build:backend && npm run typecheck:gui && npm run build:gui",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:gui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:server:static": "npm run build:gui && tsx watch src/server/index.ts",
    "dev:gui": "vite",
    "start": "npm run dev:server & npm run dev:gui",
    "server": "node dist/server/index.js",
    "cli": "node dist/cli/index.js",
    "mcp": "node dist/mcp/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@vueuse/core": "^14.2.1",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "echarts": "^6.0.0",
    "express": "^4.18.2",
    "openai": "^4.0.0",
    "pinia": "^2.1.0",
    "sql.js": "^1.10.0",
    "tdesign-vue-next": "^1.18.6",
    "uuid": "^9.0.0",
    "vue": "^3.4.0",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.2.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
