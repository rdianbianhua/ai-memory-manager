# AI Memory Configuration

# OpenAI API Key for embeddings
OPENAI_API_KEY=

# Embedding model (openai: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002)
EMBEDDING_MODEL=text-embedding-3-small

# Vector dimension (1536 for text-embedding-3-small)
EMBEDDING_DIMENSION=1536

# Database path (default: ./.ai-memory/data/memories.db)
DATABASE_PATH=./.ai-memory/data/memories.db

# HTTP API server (default: 127.0.0.1:3001)
AI_MEMORY_HOST=127.0.0.1
AI_MEMORY_PORT=3001

# Local embedding model (optional, for offline use)
# LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
